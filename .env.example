# Cookbook Environment Configuration
# Copy this to .env and update with your values

# ================================
# App Mode Configuration
# ================================
# App mode: development (standalone) or integrated (subapp in haochen.lu)
APP_MODE=development

# Subapp settings (only used in integrated mode)
SUBAPP_PREFIX=
API_PREFIX=/api

# ================================
# Environment
# ================================
ENVIRONMENT=development

# ================================
# Database
# ================================
# Development mode (standalone database)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/cookbook

# Integrated mode (shared database with schema prefix)
# DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/portfolio?options=-csearch_path%3Dcookbook

# ================================
# Redis
# ================================
# Development mode
REDIS_URL=redis://localhost:6379/0

# Integrated mode (use different DB number from haochen.lu)
# REDIS_URL=redis://redis:6379/1

# ================================
# Security
# ================================
# Development mode (standalone keys)
SECRET_KEY=dev-secret-key
SESSION_SECRET_KEY=dev-session-secret-key
ADMIN_PASSWORD=admin

# Integrated mode (MUST match haochen.lu keys!)
# SECRET_KEY=${HAOCHEN_SECRET_KEY}
# SESSION_SECRET_KEY=${HAOCHEN_SESSION_SECRET}

# ================================
# CORS Origins
# ================================
# Development mode
CORS_ORIGINS=http://localhost,https://localhost,http://localhost:3000

# Integrated mode
# CORS_ORIGINS=https://haochen.lu,https://www.haochen.lu

# ================================
# Cookies
# ================================
COOKIE_SECURE=false
COOKIE_DOMAIN=

# In production/integrated mode:
# COOKIE_SECURE=true
# COOKIE_DOMAIN=.haochen.lu

# ================================
# File Uploads
# ================================
MAX_FILE_SIZE=52428800  # 50MB in bytes
UPLOAD_DIR=uploads

# ================================
# Docker Compose Variables
# ================================
POSTGRES_DB=cookbook
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
